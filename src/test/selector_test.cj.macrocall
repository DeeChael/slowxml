/* 7.35 */func testSelector() {
/* 7.36 */    let viewXml = """
    <UIContainer id="root_view">
        <AppBar title="Settings">
            <IconButton id="back_btn" class="icon primary" />
        </AppBar>

        <List class="settings-list">
            <ListItem class="item">
                <Text class="label">Wi-Fi</Text>
                <Status class="active">Connected</Status>
            </ListItem>

            <ListItem class="item disabled">
                <Text class="label">Bluetooth</Text>
                <Status>Off</Status>
            </ListItem>

            <Footer>
                <Text class="copyright">Version 1.0.0</Text>
            </Footer>
        </List>
    </UIContainer>
    """
/* 7.37 */    
/* 7.38 */    let root = XmlParser(viewXml).parse().getOrThrow()
/* 7.39 */    
/* 7.40 */    let backBtn = root.select("#back_btn")
/* 7.41 */    expectEqual("backBtn?.attr(\"class\")", "\"icon primary\"", backBtn?.attr("class"), "icon primary", isDelta: false,)
/* 7.42 */    
/* 7.43 */    let activeStatus = root.select(".settings-list .active")
/* 7.44 */    expectEqual("activeStatus?.innerText", "\"Connected\"", activeStatus?.innerText, "Connected", isDelta: false,)
/* 7.45 */    
/* 7.46 */    let disabledItems = root.selectAll("ListItem.disabled")
/* 7.47 */    for(item in disabledItems) {
/* 7.48 */        expectEqual("item.getElementsByTagName(\"Text\")[0].innerText", "\"Bluetooth\"", item.getElementsByTagName("Text")[0].innerText, "Bluetooth", isDelta: false,)
/* 7.49 */    }
/* 7.50 */    
/* 7.51 */    let version = root.select("List > Footer > Text")
/* 7.52 */    expectEqual("version?.innerText", "\"Version 1.0.0\"", version?.innerText, "Version 1.0.0", isDelta: false,)
/* 7.53 */    
/* 7.54 */    let allLabels = root.selectAll(".label")
/* 7.55 */    expectEqual("allLabels.size", "2", allLabels.size, 2, isDelta: false,)
/* 7.56 */}
